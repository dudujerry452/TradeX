        <mxCell id="de_summary" parent="data_group" style="rounded=1;fillColor=#FFFFFF;strokeColor=#8E24AA;arcSize=6;html=1;overflow=fill;whiteSpace=wrap;" value="&lt;table style=&#39;font-size:10px;border-collapse:collapse;color:#4A148C;width:100%;&#39;&gt;&lt;tr style=&#39;background:#8E24AA;color:#FFF;&#39;&gt;&lt;th style=&#39;padding:4px 8px;border:1px solid #6A1B9A;&#39;&gt;字段名&lt;/th&gt;&lt;th style=&#39;padding:4px 8px;border:1px solid #6A1B9A;&#39;&gt;类型&lt;/th&gt;&lt;th style=&#39;padding:4px 8px;border:1px solid #6A1B9A;&#39;&gt;最大长度/精度&lt;/th&gt;&lt;th style=&#39;padding:4px 8px;border:1px solid #6A1B9A;&#39;&gt;生成方&lt;/th&gt;&lt;th style=&#39;padding:4px 8px;border:1px solid #6A1B9A;&#39;&gt;约束&lt;/th&gt;&lt;/tr&gt;&lt;tr style=&#39;background:#F3E5F5;&#39;&gt;&lt;td style=&#39;padding:3px 6px;border:1px solid #CE93D8;&#39;&gt;user_id&lt;/td&gt;&lt;td style=&#39;border:1px solid #CE93D8;&#39;&gt;String&lt;/td&gt;&lt;td style=&#39;border:1px solid #CE93D8;&#39;&gt;50 chars&lt;/td&gt;&lt;td style=&#39;border:1px solid #CE93D8;&#39;&gt;服务端&lt;/td&gt;&lt;td style=&#39;border:1px solid #CE93D8;&#39;&gt;全局唯一; UUID / prefix+random&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:3px 6px;border:1px solid #CE93D8;&#39;&gt;product_id&lt;/td&gt;&lt;td style=&#39;border:1px solid #CE93D8;&#39;&gt;String&lt;/td&gt;&lt;td style=&#39;border:1px solid #CE93D8;&#39;&gt;50 chars&lt;/td&gt;&lt;td style=&#39;border:1px solid #CE93D8;&#39;&gt;服务端 (发布时)&lt;/td&gt;&lt;td style=&#39;border:1px solid #CE93D8;&#39;&gt;全局唯一&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&#39;background:#F3E5F5;&#39;&gt;&lt;td style=&#39;padding:3px 6px;border:1px solid #CE93D8;&#39;&gt;order_id&lt;/td&gt;&lt;td style=&#39;border:1px solid #CE93D8;&#39;&gt;String&lt;/td&gt;&lt;td style=&#39;border:1px solid #CE93D8;&#39;&gt;50 chars&lt;/td&gt;&lt;td style=&#39;border:1px solid #CE93D8;&#39;&gt;服务端 (创建时)&lt;/td&gt;&lt;td style=&#39;border:1px solid #CE93D8;&#39;&gt;全局唯一&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&l