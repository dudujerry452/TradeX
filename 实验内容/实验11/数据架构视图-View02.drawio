<mxCell id="d2_ws_var" value="&lt;b&gt;WebSocket 连接状态变量&lt;/b&gt;&#10;ChatConsumer.user_connections: dict&#10;user_id -&gt; 连接数 (最大3并发)&#10;heartbeat_missed | last_heartbeat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#66BB6A;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;" parent="containerD2" vertex="1"><mxGeometry x="12" y="220" width="230" height="80" as="geometry"/></mxCell>
