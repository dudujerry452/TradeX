<mxCell id="V1" parent="V0"/>
<mxCell id="title05" value="View-05：接口架构视图&#10;基于 backend 实际代码 | Django Ninja REST API + WebSocket" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1;fontColor=#1A237E;" parent="V1" vertex="1"><mxGeometry x="300" y="5" width="900" height="40" as="geometry"/></mxCell>
<mxCell id="containerI1" value="Model-I1：接口标识与拓扑模型&#10;tradeX/api.py -&gt; core/api/__init__.py -&gt; 15 个模块 Router" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#FFF3E0;strokeColor=#E65100;fontStyle=1;fontSize=13;fontColor=#BF360C;swimlaneLine=1;" parent="V1" vertex="1"><mxGeometry x="20" y="60" width="1180" height="340" as="geometry"/></mxCell>
<mxCell id="i1_root" value="&lt;b&gt;NinjaAPI&lt;/b&gt;&#10;title: TradeX API&#10;version: 0.1.0&#10;docs_url: /docs&#10;prefix: /api/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9800;strokeColor=#E65100;fontSize=10;fontColor=#FFF;fontStyle=1;align=center;" parent="containerI1" vertex="1"><mxGeometry x="450" y="40" width="140" height="65" as="geometry"/></mxCell>
<mxCell id="i1_auth" value="&lt;b&gt;/login [认证]&lt;/b&gt;&#10;POST: 用户登录&#10;JWT Token 签发&#10;auth=None (无需鉴权)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="620" y="40" width="160" height="65" as="geometry"/></mxCell>
<mxCell id="i1_users" value="&lt;b&gt;/users [用户]&lt;/b&gt;&#10;POST: 注册用户&#10;GET: 用户信息&#10;PUT: 更新信息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="800" y="40" width="160" height="65" as="geometry"/></mxCell>
<mxCell id="i1_products" value="&lt;b&gt;/products [商品]&lt;/b&gt;&#10;GET: 列表/搜索/详情&#10;POST: 发布新商品&#10;PUT: 更新商品状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="980" y="40" width="185" height="65" as="geometry"/></mxCell>
<mxCell id="i1_categories" value="&lt;b&gt;/categories [分类]&lt;/b&gt;&#10;GET: 分类列表&#10;POST: 创建分类" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="20" y="125" width="160" height="65" as="geometry"/></mxCell>
<mxCell id="i1_tags" value="&lt;b&gt;/tags [标签]&lt;/b&gt;&#10;GET: 标签列表&#10;POST: 创建标签" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="200" y="125" width="160" height="65" as="geometry"/></mxCell>
<mxCell id="i1_prodtags" value="&lt;b&gt;/product-tags [商品标签]&lt;/b&gt;&#10;GET: 商品标签列表&#10;POST: 关联标签" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="380" y="125" width="160" height="65" as="geometry"/></mxCell>
<mxCell id="i1_utpref" value="&lt;b&gt;/user-tag-preferences&lt;/b&gt;&#10;[用户标签偏好]&#10;GET: 偏好列表 | POST: 设置偏好" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="560" y="125" width="160" height="65" as="geometry"/></mxCell>
<mxCell id="i1_favorites" value="&lt;b&gt;/product-favorites [商品收藏]&lt;/b&gt;&#10;GET: 收藏列表&#10;POST: 收藏/取消收藏" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="740" y="125" width="160" height="65" as="geometry"/></mxCell>
<mxCell id="i1_forum" value="&lt;b&gt;/forum [论坛]&lt;/b&gt;&#10;GET: categories/tags/posts/comments&#10;POST: 发帖/评论" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="920" y="125" width="165" height="65" as="geometry"/></mxCell>
<mxCell id="i1_recommendations" value="&lt;b&gt;/recommendations [推荐系统]&lt;/b&gt;&#10;GET: 热门推荐 | 个性化推荐&#10;含 trending_score 算法" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="20" y="210" width="185" height="65" as="geometry"/></mxCell>
<mxCell id="i1_orders" value="&lt;b&gt;/orders [订单]&lt;/b&gt;&#10;POST: 创建订单 | GET: 列表/详情&#10;POST: 支付/发货/取消/收货&#10;含买家/卖家双角色" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="225" y="210" width="185" height="65" as="geometry"/></mxCell>
<mxCell id="i1_notifications" value="&lt;b&gt;/notifications [通知]&lt;/b&gt;&#10;GET: 通知列表/未读数&#10;POST: 标记已读" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="430" y="210" width="185" height="65" as="geometry"/></mxCell>
<mxCell id="i1_uploads" value="&lt;b&gt;/uploads [文件]&lt;/b&gt;&#10;POST: 图片上传 COS&#10;multipart/form-data&#10;限制: 10MB, jpeg/png/webp/gif" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="635" y="210" width="185" height="65" as="geometry"/></mxCell>
<mxCell id="i1_rag" value="&lt;b&gt;/rag [RAG]&lt;/b&gt;&#10;POST: add-product (向量入库)&#10;POST: chat/stream (SSE 流式问答)&#10;模型: deepseek/deepseek-chat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="840" y="210" width="185" height="65" as="geometry"/></mxCell>
<mxCell id="i1_system" value="&lt;b&gt;/health [System]&lt;/b&gt;&#10;GET: 健康检查" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="1045" y="210" width="120" height="65" as="geometry"/></mxCell>
<mxCell id="i1_chat" value="&lt;b&gt;/chat [聊天]&lt;/b&gt;&#10;GET: conversations (对话列表)&#10;GET: messages (历史消息)&#10;POST: mark-read (标记已读)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI1" vertex="1"><mxGeometry x="430" y="295" width="185" height="35" as="geometry"/></mxCell>
<mxCell id="i1_ws" value="&lt;b&gt;WebSocket: ws/chat/&lt;/b&gt;&#10;core/routing.py -&gt; ChatConsumer&#10;消息类型: chat_message | ping/pong | read_receipt | typing | system" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCC80;strokeColor=#E65100;fontSize=9;fontStyle=1;align=center;" parent="containerI1" vertex="1"><mxGeometry x="640" y="295" width="185" height="35" as="geometry"/></mxCell>
<mxCell id="containerI2" value="Model-I2：数据元素契约模型&#10;core/api/common.py — Ninja Schema 定义 (请求/响应字段约束)" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontStyle=1;fontSize=13;fontColor=#4A148C;swimlaneLine=1;" parent="V1" vertex="1"><mxGeometry x="20" y="420" width="1180" height="340" as="geometry"/></mxCell>
<mxCell id="i2_auth_s" value="&lt;b&gt;认证 Schema&lt;/b&gt;&#10;LoginIn: email/username, password&#10;LoginOut: token, user_id, username, role&#10;RegisterIn: email, username, encrypted_password, real_name, id_card, phone, address" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI2" vertex="1"><mxGeometry x="12" y="40" width="220" height="70" as="geometry"/></mxCell>
<mxCell id="i2_user_s" value="&lt;b&gt;用户 Schema&lt;/b&gt;&#10;UserOut: user_id, username, email, real_name, role, register_status, phone, address&#10;UserUpdateIn: address, phone_display, real_name" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI2" vertex="1"><mxGeometry x="248" y="40" width="220" height="70" as="geometry"/></mxCell>
<mxCell id="i2_product_s" value="&lt;b&gt;商品 Schema&lt;/b&gt;&#10;ProductOut: 全字段 + publisher_name resolver&#10;ProductIn: product_name, description, price, stock, tag_ids&#10;ProductUpdateIn: 全部 Optional&#10;ProductStatusUpdateIn/Out: product_status + message" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI2" vertex="1"><mxGeometry x="484" y="40" width="220" height="70" as="geometry"/></mxCell>
<mxCell id="i2_cattag_s" value="&lt;b&gt;分类/标签 Schema&lt;/b&gt;&#10;CategoryOut/In: category_id, name, sort_order, is_active&#10;TagOut/In: tag_id, tag_name, category, usage_count&#10;ProductTagOut/In | UserTagPreferenceOut/In" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI2" vertex="1"><mxGeometry x="720" y="40" width="220" height="70" as="geometry"/></mxCell>
<mxCell id="i2_fav_s" value="&lt;b&gt;收藏/推荐 Schema&lt;/b&gt;&#10;ProductFavoriteOut/In: user_id + product_id&#10;RecommendationOut: 继承 ProductOut + relevance_score, trending_score, is_favorited" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI2" vertex="1"><mxGeometry x="956" y="40" width="212" height="70" as="geometry"/></mxCell>
<mxCell id="i2_order_s" value="&lt;b&gt;订单 Schema&lt;/b&gt;&#10;OrderOut: order_id, buyer_id, seller_id, total_amount, order_status+display, logistics, products: List[OrderProductOut]&#10;OrderCreateIn: product_id, quantity, address, phone&#10;OrderShipIn | OrderCancelIn | OrderPayIn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI2" vertex="1"><mxGeometry x="12" y="125" width="240" height="105" as="geometry"/></mxCell>
<mxCell id="i2_forum_s" value="&lt;b&gt;论坛 Schema&lt;/b&gt;&#10;ForumCategoryOut/In, ForumTagOut&#10;ForumPostOut: includes comments list&#10;ForumPostSummaryOut, ForumPostIn&#10;ForumCommentOut/In&#10;is_liked: bool (根据当前用户动态计算)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI2" vertex="1"><mxGeometry x="268" y="125" width="240" height="105" as="geometry"/></mxCell>
<mxCell id="i2_notifrag_s" value="&lt;b&gt;通知/RAG/聊天 Schema&lt;/b&gt;&#10;NotificationOut: type, title, content, is_read&#10;UnreadCountOut: count&#10;RagChatIn: question, n_results&#10;RagChatOut: answer, products: list[dict]&#10;ConversationOut | ChatMessageOut | SendMessageIn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI2" vertex="1"><mxGeometry x="524" y="125" width="270" height="105" as="geometry"/></mxCell>
<mxCell id="i2_util_s" value="&lt;b&gt;通用/工具 Schema&lt;/b&gt;&#10;SuccessOut: success(bool)+message&#10;ImageUploadOut: url, key, filename&#10;SellerStatsOut: 卖家统计数据&#10;OrderLogOut: 订单操作日志&#10;JWT: HS256 算法, 30天过期" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI2" vertex="1"><mxGeometry x="810" y="125" width="240" height="105" as="geometry"/></mxCell>
<mxCell id="i2_auth_class" value="&lt;b&gt;认证器: AuthBearer(HttpBearer)&lt;/b&gt;&#10;authenticate(request, token) -&gt; 解析 JWT&#10;payload[&quot;user_id&quot;] -&gt; User.objects.get()&#10;异常: ExpiredSignatureError / InvalidTokenError -&gt; None" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;strokeColor=#6A1B9A;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;fontColor=#FFF;" parent="containerI2" vertex="1"><mxGeometry x="12" y="248" width="390" height="55" as="geometry"/></mxCell>
<mxCell id="i2_gen_token" value="&lt;b&gt;generate_token(user) -&gt; str&lt;/b&gt;&#10;payload = { user_id, username, exp: now()+30天 }&#10;jwt.encode(payload, JWT_SECRET, algorithm=&quot;HS256&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;strokeColor=#6A1B9A;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;fontColor=#FFF;" parent="containerI2" vertex="1"><mxGeometry x="418" y="248" width="350" height="55" as="geometry"/></mxCell>
<mxCell id="containerI3" value="Model-I3：数据集合体契约模型&#10;列表/分页/嵌套结构定义" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#E8EAF6;strokeColor=#3949AB;fontStyle=1;fontSize=13;fontColor=#1A237E;swimlaneLine=1;" parent="V1" vertex="1"><mxGeometry x="20" y="780" width="580" height="260" as="geometry"/></mxCell>
<mxCell id="i3_list" value="&lt;b&gt;列表响应模式&lt;/b&gt;&#10;GET -&gt; response=list[Schema]&#10;/products/ -&gt; list[ProductOut]&#10;/categories/ -&gt; list[CategoryOut]&#10;/tags/ -&gt; list[TagOut]&#10;/recommendations/ -&gt; list[RecommendationOut]&#10;/forum/posts/ -&gt; list[ForumPostSummaryOut]&#10;/chat/conversations -&gt; list[ConversationOut]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#5C6BC0;fontSize=9;align=left;spacingLeft=5;verticalAlign=top;" parent="containerI3" vertex="1"><mxGeometry x="12" y="38" width="270" height="100" as="geometry"/></mxCell>
<mxCell id="i3_aggregate" value="&lt;b&gt;聚合响应模式&lt;/b&gt;&#10;OrderListOut: {orders: List[OrderOut], total: int}&#10;OrderOut.products: List[OrderProductOut] (嵌套)&#10;ForumPostOut.comments: list[ForumCommentOut]&#10;ChatMessageListOut: {messages: List, total, has_more}&#10;RagChatOut.products: list[dict[str, Any]]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#5C6BC0;fontSize=9;align=left;spacingLeft=5;verticalAlign=top;" parent="containerI3" vertex="1"><mxGeometry x="296" y="38" width="272" height="100" as="geometry"/></mxCell>
<mxCell id="i3_pagination" value="&lt;b&gt;分页与查询模式&lt;/b&gt;&#10;参数: limit (默认10-20), offset (默认0), before_id&#10;排序: sort (trending/time), ordering (-published_at, hot)&#10;筛选: status, role (buyer/seller), category_id, q (搜索)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#5C6BC0;fontSize=9;align=left;spacingLeft=5;verticalAlign=top;" parent="containerI3" vertex="1"><mxGeometry x="12" y="152" width="270" height="72" as="geometry"/></mxCell>
<mxCell id="i3_status" value="&lt;b&gt;响应状态码模式&lt;/b&gt;&#10;201: 创建成功 (发布商品/创建订单)&#10;200: 查询/更新成功&#10;401: 认证失败 | 403: 权限不足&#10;404: 资源不存在 | 400: 参数错误 | 500: 服务端错误" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#5C6BC0;fontSize=9;align=left;spacingLeft=5;verticalAlign=top;" parent="containerI3" vertex="1"><mxGeometry x="296" y="152" width="272" height="72" as="geometry"/></mxCell>
<mxCell id="containerI4" value="Model-I4：通信方法模型&#10;REST API 方法与 WebSocket 通道" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#E0F7FA;strokeColor=#00838F;fontStyle=1;fontSize=13;fontColor=#006064;swimlaneLine=1;" parent="V1" vertex="1"><mxGeometry x="630" y="780" width="570" height="260" as="geometry"/></mxCell>
<mxCell id="i4_get" value="&lt;b&gt;GET — 查询/检索&lt;/b&gt;&#10;list_products | get_product&#10;search_products (模糊搜索, auth=None)&#10;list_categories | list_tags&#10;list_orders (role=buyer/seller+status)&#10;get_forum_post (+view_count++)&#10;get_messages (分页before_id)&#10;get_conversations | get_unread_count" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2EBF2;strokeColor=#00ACC1;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI4" vertex="1"><mxGeometry x="12" y="38" width="270" height="105" as="geometry"/></mxCell>
<mxCell id="i4_post" value="&lt;b&gt;POST — 创建/操作&lt;/b&gt;&#10;create_product | create_order&#10;login (auth=None) | register&#10;pay_order (模拟支付)&#10;create_forum_post | create_forum_comment&#10;rag_add_product | rag_chat_stream (SSE)&#10;upload_image (multipart/form-data)&#10;mark_messages_read" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2EBF2;strokeColor=#00ACC1;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI4" vertex="1"><mxGeometry x="296" y="38" width="262" height="105" as="geometry"/></mxCell>
<mxCell id="i4_ws" value="&lt;b&gt;WebSocket — 实时双向通信&lt;/b&gt;&#10;ws://host/ws/chat/?token=JWT&#10;connect: JWT认证 -&gt; 加入user_{id}组 (最大3并发)&#10;receive: chat_message | ping/pong | read_receipt | typing&#10;disconnect: 离开用户组，减少连接计数&#10;Channel Layer 事件: chat_message, read_receipt, typing_status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2EBF2;strokeColor=#00ACC1;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI4" vertex="1"><mxGeometry x="12" y="156" width="440" height="70" as="geometry"/></mxCell>
<mxCell id="i4_put" value="&lt;b&gt;PUT — 更新&lt;/b&gt;&#10;update_user (地址/手机/姓名)&#10;update_product_status (审核/上下架)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2EBF2;strokeColor=#00ACC1;fontSize=9;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI4" vertex="1"><mxGeometry x="464" y="156" width="94" height="70" as="geometry"/></mxCell>
<mxCell id="containerI5" value="Model-I5：协议特性模型&#10;认证、安全、传输协议特性" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#E8F5E9;strokeColor=#2E7D32;fontStyle=1;fontSize=13;fontColor=#1B5E20;swimlaneLine=1;" parent="V1" vertex="1"><mxGeometry x="20" y="1060" width="600" height="260" as="geometry"/></mxCell>
<mxCell id="i5_jwt" value="&lt;b&gt;JWT Bearer 认证&lt;/b&gt;&#10;Header: Authorization: Bearer &lt;token&gt;&#10;算法: HS256 | 有效期: 30天&#10;payload: {user_id, username, exp}&#10;AuthBearer(HttpBearer) 自动解析&#10;auth=None 标记公开接口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#66BB6A;fontSize=10;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI5" vertex="1"><mxGeometry x="12" y="38" width="280" height="80" as="geometry"/></mxCell>
<mxCell id="i5_cors" value="&lt;b&gt;CORS 跨域策略&lt;/b&gt;&#10;corsheaders.CorsMiddleware&#10;CORS_ALLOW_CREDENTIALS: True&#10;CORS_ALLOWED_ORIGINS: 从env解析&#10;开发: CORS_ALLOW_ALL_ORIGINS=True&#10;生产: 白名单模式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#66BB6A;fontSize=10;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI5" vertex="1"><mxGeometry x="306" y="38" width="282" height="80" as="geometry"/></mxCell>
<mxCell id="i5_csrf" value="&lt;b&gt;CSRF / 安全 Cookie&lt;/b&gt;&#10;CsrfViewMiddleware&#10;CSRF_TRUSTED_ORIGINS: 环境变量配置&#10;SESSION_COOKIE_SECURE: 生产环境启用&#10;CSRF_COOKIE_SECURE: 生产环境启用&#10;SESSION_COOKIE_SAMESITE: Lax" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#66BB6A;fontSize=10;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI5" vertex="1"><mxGeometry x="12" y="132" width="280" height="80" as="geometry"/></mxCell>
<mxCell id="i5_content" value="&lt;b&gt;传输格式&lt;/b&gt;&#10;Content-Type: application/json (默认)&#10;multipart/form-data (图片上传)&#10;SSE: text/event-stream (RAG流式问答)&#10;WebSocket: JSON 文本帧&#10;ASGI: Daphne + ProtocolTypeRouter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#66BB6A;fontSize=10;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI5" vertex="1"><mxGeometry x="306" y="132" width="282" height="80" as="geometry"/></mxCell>
<mxCell id="i5_error" value="&lt;b&gt;错误处理机制&lt;/b&gt;&#10;HttpError(status, message) -&gt; JSON响应&#10;WebSocket: close(code=4001-4005) 认证错误码&#10;WebSocket error: {&quot;type&quot;:&quot;error&quot;,&quot;message&quot;:&quot;...&quot;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#66BB6A;fontSize=10;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI5" vertex="1"><mxGeometry x="80" y="225" width="440" height="25" as="geometry"/></mxCell>
<mxCell id="containerI6" value="Model-I6：物理兼容性模型&#10;运行环境与基础设施兼容性" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#FBE9E7;strokeColor=#BF360C;fontStyle=1;fontSize=13;fontColor=#BF360C;swimlaneLine=1;" parent="V1" vertex="1"><mxGeometry x="650" y="1060" width="550" height="260" as="geometry"/></mxCell>
<mxCell id="i6_runtime" value="&lt;b&gt;运行时环境&lt;/b&gt;&#10;Python 3.x + Django 5.0&#10;ASGI: Daphne (异步服务器)&#10;WSGI: Gunicorn (生产备用)&#10;Docker: Dockerfile 容器化部署" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#D81B60;fontSize=10;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI6" vertex="1"><mxGeometry x="12" y="38" width="260" height="75" as="geometry"/></mxCell>
<mxCell id="i6_db" value="&lt;b&gt;数据库兼容性&lt;/b&gt;&#10;SQLite3: 开发环境 (本地文件)&#10;PostgreSQL: 生产环境 (DATABASE_URL)&#10;自动切换: dj_database_url.parse()&#10;迁移: Django Migrations (0001-0008)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#D81B60;fontSize=10;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI6" vertex="1"><mxGeometry x="286" y="38" width="252" height="75" as="geometry"/></mxCell>
<mxCell id="i6_cache" value="&lt;b&gt;缓存/通道兼容性&lt;/b&gt;&#10;LocMemCache: 开发 (内存)&#10;RedisCache: 生产 (django_redis)&#10;InMemoryChannelLayer: 开发 (WebSocket)&#10;RedisChannelLayer: 生产 (WebSocket)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#D81B60;fontSize=10;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI6" vertex="1"><mxGeometry x="12" y="128" width="260" height="75" as="geometry"/></mxCell>
<mxCell id="i6_external" value="&lt;b&gt;外部服务兼容性&lt;/b&gt;&#10;ChromaDB: 向量存储 (RAG)&#10;Tencent COS: 文件存储 (图片上传)&#10;OpenRouter API: LLM 服务 (deepseek)&#10;CORS: 前端跨域 (localhost:5173)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#D81B60;fontSize=10;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI6" vertex="1"><mxGeometry x="286" y="128" width="252" height="75" as="geometry"/></mxCell>
<mxCell id="i6_deploy" value="&lt;b&gt;部署与CI/CD&lt;/b&gt;&#10;Docker Compose: 多服务编排&#10;环境切换: DJANGO_ENV=local/development/production&#10;.env 文件: 环境变量隔离&#10;静态文件: STATIC_ROOT + WhiteNoise" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#D81B60;fontSize=10;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI6" vertex="1"><mxGeometry x="12" y="218" width="260" height="32" as="geometry"/></mxCell>
<mxCell id="i6_protocol" value="&lt;b&gt;支持的协议&lt;/b&gt;&#10;HTTP/1.1: REST API (Django Ninja)&#10;WebSocket: 实时通信 (Django Channels)&#10;SSE: 流式推送 (RAG chat/stream)&#10;HTTPS: 生产环境 (SECURE Cookies)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#D81B60;fontSize=10;align=left;spacingLeft=4;verticalAlign=top;" parent="containerI6" vertex="1"><mxGeometry x="286" y="218" width="252" height="32" as="geometry"/></mxCell>
</root>
</mxGraphModel>
</diagram>
</mxfile>
