          <mxGeometry height="72" width="270" x="12" y="152" as="geometry" />
        </mxCell>
        <mxCell id="i3_status" parent="containerI3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#5C6BC0;fontSize=9;align=left;spacingLeft=5;verticalAlign=top;" value="&lt;b&gt;响应状态码模式&lt;/b&gt;&#xa;201: 创建成功 (发布商品/创建订单)&#xa;200: 查询/更新成功&#xa;401: 认证失败 | 403: 权限不足&#xa;404: 资源不存在 | 400: 参数错误 | 500: 服务端错误" vertex="1">
          <mxGeometry height="72" width="272" x="296" y="152" as="geometry" />
        </mxCell>
