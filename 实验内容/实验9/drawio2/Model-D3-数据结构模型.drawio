        <mxCell id="g1" value="&lt;b&gt;用户与权限&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#E3F2FD;strokeColor=#1E88E5;fontColor=#1E88E5;rounded=1;arcSize=8;fontSize=14;fontStyle=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="420" height="440" as="geometry" />
        </mxCell>

        <mxCell id="user" value="&lt;b&gt;User&lt;/b&gt;&#xa;─────────────────────────────&#xa;PK  user_id : CharField(50)&#xa;    username : CharField  «unique»&#xa;    email : EmailField  «unique»&#xa;    phone : CharField  «unique»&#xa;    encrypted_password : CharField&#xa;        → PBKDF2 hash&#xa;    real_name : CharField&#xa;    id_card : CharField  «unique»&#xa;    contact_phone : CharField&#xa;    address : TextField&#xa;    role : RoleChoices&#xa;    register_status : RegisterStatusChoices&#xa;    register_time : DateTimeField&#xa;    last_login : DateTimeField" style="shape=mxgraph.basic.rect;dx=10;fillColor=#BBDEFB;strokeColor=#1E88E5;fontColor=#1A237E;rounded=1;arcSize=8;whiteSpace=wrap;html=0;align=left;spacingLeft=10;spacingTop=4;spacingBottom=4;fontSize=11;fontFamily=Consolas;" vertex="1" parent="g1">
          <mxGeometry x="20" y="45" width="380" height="370" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- GROUP 2: 商品与分类 (Product & Category)                      -->
        <!-- ============================================================ -->
        <mxCell id="g2" value="&lt;b&gt;商品与分类&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#E3F2FD;strokeColor=#1E88E5;fontColor=#1E88E5;rounded=1;arcSize=8;fontSize=14;fontStyle=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="500" y="100" width="700" height="610" as="geometry" />
        </mxCell>

        <mxCell id="category" value="&lt;b&gt;Category&lt;/b&gt;&#xa;──────────────────────&#xa;PK  category_id : AutoField&#xa;    name : CharField&#xa;    description : TextField&#xa;    sort_order : IntegerField&#xa;    is_active : BooleanField&#xa;        → soft delete" style="shape=mxgraph.basic.rect;dx=10;fillColor=#BBDEFB;strokeColor=#1E88E5;fontColor=#1A237E;rounded=1;arcSize=8;whiteSpace=wrap;html=0;align=left;spacingLeft=10;spacingTop=4;spacingBottom=4;fontSize=11;fontFamily=Consolas;" vertex="1" parent="g2">
          <mxGeometry x="20" y="45" width="280" height="170" as="geometry" />
        </mxCell>

        <mxCell id="product" value="&lt;b&gt;Product&lt;/b&gt;&#xa;──────────────────────────────&#xa;PK  product_id : AutoField&#xa;FK  publisher → User&#xa;FK  category_ref → Category (SET_NULL)&#xa;    product_name : CharField&#xa;    description : TextField&#xa;    image_url : URLField&#xa;    price : DecimalField(10,2)&#xa;    stock : IntegerField&#xa;    view_count : IntegerField&#xa;    sales_count : IntegerField&#xa;    favorite_count : IntegerField&#xa;    avg_rating : DecimalField&#xa;    product_status : StatusChoices&#xa;    published_at : DateTimeField&#xa;    reviewed_at : DateTimeField" style="shape=mxgraph.basic.rect;dx=10;fillColor=#BBDEFB;strokeColor=#1E88E5;fontColor=#1A237E;rounded=1;arcSize=8;whiteSpace=wrap;html=0;align=left;spacingLeft=10;spacingTop=4;spacingBottom=4;fontSize=11;fontFamily=Consolas;" vertex="1" parent="g2">
          <mxGeometry x="20" y="240" width="340" height="350" as="geometry" />
        </mxCell>

        <mxCell id="tag" value="&lt;b&gt;Tag&lt;/b&gt;&#xa;──────────────────────&#xa;PK  tag_id : AutoField&#xa;    tag_name : CharField&#xa;    category : CharField&#xa;    usage_count : IntegerField" style="shape=mxgraph.basic.rect;dx=10;fillColor=#BBDEFB;strokeColor=#1E88E5;fontColor=#1A237E;rounded=1;arcSize=8;whiteSpace=wrap;html=0;align=left;spacingLeft=10;spacingTop=4;spacingBottom=4;fontSize=11;fontFamily=Consolas;" vertex="1" parent="g2">
          <mxGeometry x="400" y="45" width="270" height="130" as="geometry" />
        </mxCell>

        <mxCell id="producttag" value="&lt;b&gt;ProductTag&lt;/b&gt;  «junction»&#xa;──────────────────────────&#xa;FK  product → Product&#xa;FK  tag → Tag&#xa;    weight : FloatField&#xa;    tagged_time : DateTimeField&#xa;  unique_together(product, tag)" style="shape=mxgraph.basic.rect;dx=10;fillColor=#BBDEFB;strokeColor=#1E88E5;fontColor=#1A237E;rounded=1;arcSize=8;whiteSpace=wrap;html=0;align=left;spacingLeft=10;spacingTop=4;spacingBottom=4;fontSize=11;fontFamily=Consolas;" vertex="1" parent="g2">
          <mxGeometry x="400" y="200" width="270" height="160" as="geometry" />
