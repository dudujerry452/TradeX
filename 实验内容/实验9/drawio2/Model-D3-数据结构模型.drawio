        <mxCell id="g3" value="&lt;b&gt;审查&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#E3F2FD;strokeColor=#1E88E5;fontColor=#1E88E5;rounded=1;arcSize=8;fontSize=14;fontStyle=1;collapsible=0;" vertex="1" parent="1">
