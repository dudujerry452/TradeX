        <mxCell id="message" value="&lt;b&gt;Message&lt;/b&gt;&#xa;──────────────────────────────&#xa;FK  product → Product&#xa;FK  user → User&#xa;    content : TextField&#xa;    parent_message : FK (self)&#xa;    created_at : DateTimeField&#xa;→ Product messages &amp;&#xa;  merchant replies" style="shape=mxgraph.basic.rect;dx=10;fillColor=#BBDEFB;strokeColor=#1E88E5;fontColor=#1A237E;rounded=1;arcSize=8;whiteSpace=wrap;html=0;align=left;spacingLeft=10;spacingTop=4;spacingBottom=4;fontSize=11;fontFamily=Consolas;" vertex="1" parent="g5">
