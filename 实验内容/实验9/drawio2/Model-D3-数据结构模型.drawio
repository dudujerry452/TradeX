        <mxCell id="registerreview" value="&lt;b&gt;RegisterReview&lt;/b&gt;&#xa;──────────────────────────────&#xa;PK  review_id : AutoField&#xa;O2O pending_user → User&#xa;FK  admin → User&#xa;    result : ResultChoices&#xa;    opinion : TextField&#xa;    review_time : DateTimeField" style="shape=mxgraph.basic.rect;dx=10;fillColor=#BBDEFB;strokeColor=#1E88E5;fontColor=#1A237E;rounded=1;arcSize=8;whiteSpace=wrap;html=0;align=left;spacingLeft=10;spacingTop=4;spacingBottom=4;fontSize=11;fontFamily=Consolas;" vertex="1" parent="g3">
          <mxGeometry x="20" y="45" width="380" height="185" as="geometry" />
