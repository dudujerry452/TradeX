        <mxCell id="forumcategory" value="&lt;b&gt;ForumCategory&lt;/b&gt;&#xa;──────────────────────────────&#xa;PK  category_id : AutoField&#xa;    name : CharField&#xa;    description : TextField&#xa;    sort_order : IntegerField&#xa;    is_active : BooleanField" style="shape=mxgraph.basic.rect;dx=10;fillColor=#BBDEFB;strokeColor=#1E88E5;fontColor=#1A237E;rounded=1;arcSize=8;whiteSpace=wrap;html=0;align=left;spacingLeft=10;spacingTop=4;spacingBottom=4;fontSize=11;fontFamily=Consolas;" vertex="1" parent="g6">
