        </mxCell>

        <mxCell id="chatmessage" value="&lt;b&gt;ChatMessage&lt;/b&gt;&#xa;──────────────────────────────&#xa;FK  sender → User&#xa;FK  receiver → User&#xa;FK  product → Product (optional)&#xa;FK  order → Order (optional)&#xa;    content : TextField&#xa;    is_read : BooleanField&#xa;    created_at : DateTimeField&#xa;─── Indexes ───&#xa;  idx(sender, receiver)&#xa;  idx(receiver, is_read)&#xa;  idx(created_at)" style="shape=mxgraph.basic.rect;dx=10;fillColor=#BBDEFB;strokeColor=#1E88E5;fontColor=#1A237E;rounded=1;arcSize=8;whiteSpace=wrap;html=0;align=left;spacingLeft=10;spacingTop=4;spacingBottom=4;fontSize=11;fontFamily=Consolas;" vertex="1" parent="g5">
          <mxGeometry x="20" y="280" width="340" height="265" as="geometry" />
