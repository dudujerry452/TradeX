        <mxCell id="orderlog" value="&lt;b&gt;OrderLog&lt;/b&gt;  «immutable audit»&#xa;──────────────────────────────&#xa;PK  log_id : AutoField&#xa;FK  order → Order&#xa;FK  operator → User&#xa;    action : ActionChoices&#xa;    from_status : CharField&#xa;    to_status : CharField&#xa;    remark : TextField&#xa;    created_at : DateTimeField" style="shape=mxgraph.basic.rect;dx=10;fillColor=#BBDEFB;strokeColor=#1E88E5;fontColor=#1A237E;rounded=1;arcSize=8;whiteSpace=wrap;html=0;align=left;spacingLeft=10;spacingTop=4;spacingBottom=4;fontSize=11;fontFamily=Consolas;" vertex="1" parent="g4">
