        <mxCell id="e_fpost_fpt" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1E88E5;strokeWidth=1.5;exitX=1;exitY=0.2;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="g6" source="forumpost" target="forumposttag">
