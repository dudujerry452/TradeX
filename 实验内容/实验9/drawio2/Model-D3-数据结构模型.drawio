        <mxCell id="g4" value="&lt;b&gt;订单与交易&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#E3F2FD;strokeColor=#1E88E5;fontColor=#1E88E5;rounded=1;arcSize=8;fontSize=14;fontStyle=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="500" y="750" width="700" height="820" as="geometry" />
        </mxCell>

        <mxCell id="order" value="&lt;b&gt;Order&lt;/b&gt;&#xa;─────────────────────────────────&#xa;PK  order_id : AutoField&#xa;FK  buyer → User (PROTECT)&#xa;FK  seller → User (PROTECT)&#xa;    total_amount : DecimalField(12,2)&#xa;    address_snapshot : TextField&#xa;    phone_snapshot : CharField&#xa;        → snapshot strategy&#xa;    order_status : StatusChoices&#xa;    order_time : DateTimeField&#xa;    pay_time : DateTimeField&#xa;    ship_time : DateTimeField&#xa;    receive_time : DateTimeField&#xa;    auto_receive_time : DateTimeField&#xa;    logistics_company : CharField&#xa;    logistics_number : CharField&#xa;    logistics_info : JSONField&#xa;    cancel_reason : TextField" style="shape=mxgraph.basic.rect;dx=10;fillColor=#BBDEFB;strokeColor=#1E88E5;fontColor=#1A237E;rounded=1;arcSize=8;whiteSpace=wrap;html=0;align=left;spacingLeft=10;spacingTop=4;spacingBottom=4;fontSize=11;fontFamily=Consolas;" vertex="1" parent="g4">
          <mxGeometry x="20" y="45" width="370" height="410" as="geometry" />
        </mxCell>

        <mxCell id="orderdetail" value="&lt;b&gt;OrderDetail&lt;/b&gt;&#xa;──────────────────────────────&#xa;PK  detail_id : AutoField&#xa;FK  order → Order&#xa;FK  product → Product&#xa;    quantity : IntegerField&#xa;    price_snapshot : DecimalField&#xa;    subtotal : DecimalField" style="shape=mxgraph.basic.rect;dx=10;fillColor=#BBDEFB;strokeColor=#1E88E5;fontColor=#1A237E;rounded=1;arcSize=8;whiteSpace=wrap;html=0;align=left;spacingLeft=10;spacingTop=4;spacingBottom=4;fontSize=11;fontFamily=Consolas;" vertex="1" parent="g4">
