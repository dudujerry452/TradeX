        <mxCell id="forumpost" value="&lt;b&gt;ForumPost&lt;/b&gt;&#xa;──────────────────────────────&#xa;PK  post_id : AutoField&#xa;FK  author → User&#xa;FK  category → ForumCategory&#xa;    title : CharField&#xa;    content : TextField&#xa;    cover_image_url : URLField&#xa;    view_count : IntegerField&#xa;    like_count : IntegerField&#xa;    comment_count : IntegerField&#xa;    status : PUBLISHED / HIDDEN&#xa;    is_pinned : BooleanField&#xa;    published_at : DateTimeField&#xa;    updated_at : DateTimeField" style="shape=mxgraph.basic.rect;dx=10;fillColor=#BBDEFB;strokeColor=#1E88E5;fontColor=#1A237E;rounded=1;arcSize=8;whiteSpace=wrap;html=0;align=left;spacingLeft=10;spacingTop=4;spacingBottom=4;fontSize=11;fontFamily=Consolas;" vertex="1" parent="g6">
