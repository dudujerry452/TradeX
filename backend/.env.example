# 基础配置模板
# 复制此文件为 .env 用于本地开发，或 .env.production 用于生产环境

# ============================================
# Django 核心配置
# ============================================

# 安全密钥（生产环境必须更改！可使用: openssl rand -base64 50）
SECRET_KEY=your-secret-key-here-change-in-production

# 调试模式（生产环境必须设为 False）
DEBUG=False

# 允许的主机（生产环境必须设置具体域名）
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# 数据库配置（生产环境使用 PostgreSQL）
# ============================================

# 开发环境：SQLite
DATABASE_URL=sqlite:///db.sqlite3

# 生产环境：PostgreSQL（取消下面注释）
# DATABASE_URL=postgres://user:password@db:5432/tradex
# DB_NAME=tradex
# DB_USER=tradex
# DB_PASSWORD=your-strong-db-password
# DB_HOST=db
# DB_PORT=5432

# ============================================
# Redis 缓存（生产环境推荐）
# ============================================

# 开发环境：不使用缓存
REDIS_URL=

# 生产环境（取消下面注释）
# REDIS_URL=redis://redis:6379/0
# CACHE_ENABLED=True

# ============================================
# AI / LLM 配置
# ============================================

OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================
# CORS 配置（生产环境必须限制具体域名）
# ============================================

# 开发环境：允许所有
CORS_ALLOW_ALL_ORIGINS=True

# 生产环境：只允许特定域名（取消下面注释，修改为你的域名）
# CORS_ALLOW_ALL_ORIGINS=False
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# ============================================
# 安全设置（生产环境必须启用 HTTPS）
# ============================================

# HTTPS 安全 Cookie（生产环境必须设为 True）
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Cookie SameSite 设置
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# ============================================
# 静态文件和媒体文件
# ============================================

STATIC_URL=/static/
MEDIA_URL=/media/

# 生产环境使用 AWS S3 或 CDN（可选）
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=

# ============================================
# 日志级别
# ============================================

LOG_LEVEL=INFO

# ============================================
# 其他配置
# ============================================

# 时区
TIME_ZONE=Asia/Shanghai

# 语言
LANGUAGE_CODE=zh-hans
